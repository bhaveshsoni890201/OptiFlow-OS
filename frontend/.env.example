# OptiFlow OS — Environment Configuration
# Copy this file to .env.development and .env.production with appropriate values

# API Configuration
VITE_API_BASE_URL=http://localhost:8000
VITE_API_TIMEOUT=15000

# Feature Flags
VITE_ENABLE_MOCK=true

# Error Tracking (Sentry)
VITE_SENTRY_DSN=

# Logging
VITE_LOG_LEVEL=warn

# App Version (used in Sentry releases)
VITE_APP_VERSION=0.0.0

# Business Rules
VITE_OFFICE_START_TIME=09:00

# Localization
VITE_DEFAULT_LANGUAGE=en
